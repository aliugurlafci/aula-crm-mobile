{
  "expo": {
    "name": "Aula POS",
    "slug": "aula-crm-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aulacrmmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.ugurcorp.aulacrmmobile",
      "icon": "./assets/expo.icon",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Aula POS uses the camera to scan product barcodes and QR codes at checkout.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.ugurcorp.aulacrmmobile",
      "adaptiveIcon": {
        "backgroundColor": "#0B0F1A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Aula POS uses the camera to scan product barcodes and QR codes.",
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B0F1A",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 96
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "defaultApiBaseUrl": "http://localhost:4000",
      "router": {},
      "eas": {
        "projectId": "9e8d5fb4-600e-4359-a396-9d964d3e42fe"
      }
    },
    "owner": "ugurcorp",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9e8d5fb4-600e-4359-a396-9d964d3e42fe"
    }
  }
}
